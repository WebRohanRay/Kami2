{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@features/*":       ["src/features/*"],
      "@shared/*":         ["src/shared/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@core/*":           ["src/core/*"],
      "@assets/*":         ["assets/*"]
    }
  }
}